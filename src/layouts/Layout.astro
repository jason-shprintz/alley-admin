---
interface Props {
  title?: string;
  description?: string;
  keywords?: string;
  ogImage?: string;
  canonical?: string;
}

const {
  title = 'Alley Admin - Coming Soon | Professional Bowling League Management Software',
  description = 'Professional bowling league management software. Strike! Your league administration just got easier. Manage teams, track scores, and organize tournaments effortlessly.',
  keywords = 'bowling league management, bowling software, league management system, bowling scores, team management, bowling statistics, sports league software, bowling alley software, bowling league secretary, CDE software alternative',
  ogImage = '/og-image.png',
  canonical,
} = Astro.props as Props;

if (!Astro.site) {
  throw new Error(
    'Astro.site must be configured to generate canonical and social metadata URLs. Set `site` in astro.config.mjs.'
  );
}

const siteUrl = Astro.site;
const canonicalUrl = canonical || Astro.url.pathname;
const fullCanonicalUrl = new URL(canonicalUrl, siteUrl).href;
const fullOgImageUrl = new URL(ogImage, siteUrl).href;

// Structured Data for AEO (AI Engine Optimization)
const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Alley Admin',
  applicationCategory: 'BusinessApplication',
  operatingSystem: 'Web',
  description: description,
  url: siteUrl.href,
  author: {
    '@type': 'Person',
    name: 'Jason Shprintz',
    url: 'https://jasonshprintz.com',
  },
  publisher: {
    '@type': 'Organization',
    name: 'Alley Admin',
    url: siteUrl.href,
  },
  screenshot: [fullOgImageUrl],
  featureList: [
    'League Management',
    'Score Tracking',
    'Team Statistics',
    'Tournament Organization',
    'Digital Scorekeeping',
    'Performance Analytics',
    'Automatic Handicap Calculations',
    'Schedule Generation',
    'Financial Tracking',
  ],
};

const organizationData = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Alley Admin',
  url: siteUrl.href,
  logo: new URL('/favicon.svg', siteUrl).href,
  sameAs: [
    'https://github.com/jason-shprintz',
    'https://jasonshprintz.com',
    'https://alleyadmin.com',
  ],
  description:
    'Alley Admin provides professional bowling league management software for bowling alleys, leagues, and tournaments.',
};

const websiteData = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Alley Admin',
  url: siteUrl.href,
  description: description,
};

/**
 * Safely serialize an object to a JSON-LD string for use with `set:html`.
 * Escapes `<`, `>`, and `&` to their Unicode equivalents to prevent a
 * malicious value from breaking out of the `<script>` tag and injecting HTML.
 */
function safeJsonLd(data: object): string {
  return JSON.stringify(data)
    .replace(/</g, '\\u003c')
    .replace(/>/g, '\\u003e')
    .replace(/&/g, '\\u0026');
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="author" content="Alley Admin" />
    <meta name="robots" content="index, follow" />
    <meta name="language" content="English" />
    <meta name="theme-color" content="#d97706" />
    <meta name="generator" content={Astro.generator} />

    <!-- Canonical URL -->
    <link rel="canonical" href={fullCanonicalUrl} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={fullCanonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={fullOgImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta
      property="og:image:alt"
      content="Alley Admin — Professional Bowling League Management Software"
    />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:site_name" content="Alley Admin" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={fullCanonicalUrl} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={fullOgImageUrl} />
    <meta
      name="twitter:image:alt"
      content="Alley Admin — Professional Bowling League Management Software"
    />

    <!-- Structured Data (JSON-LD) for AEO -->
    <script type="application/ld+json" set:html={safeJsonLd(structuredData)} />
    <script type="application/ld+json" set:html={safeJsonLd(organizationData)} />
    <script type="application/ld+json" set:html={safeJsonLd(websiteData)} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Fonts (async load to avoid render-blocking) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap"
      />
    </noscript>

    <!-- Sitemap -->
    <link rel="sitemap" type="application/xml" href="/sitemap-index.xml" />

    <!-- Prevent PWA install prompt -->
    <script>
      window.addEventListener('beforeinstallprompt', (e) => {
        e.preventDefault();
      });
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  *,
  *::before,
  *::after {
    box-sizing: border-box;
  }

  html,
  body {
    margin: 0;
    padding: 0;
    width: 100%;
    min-height: 100vh;
    font-family:
      'Inter',
      -apple-system,
      BlinkMacSystemFont,
      'Segoe UI',
      Roboto,
      Oxygen,
      Ubuntu,
      Cantarell,
      sans-serif;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  body {
    background: #1a1410;
    color: #f5f1e8;
    overflow-x: hidden;
  }
</style>
