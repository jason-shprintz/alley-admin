---
// Retro bowling icon with vintage scoreboard aesthetic
---

<svg
  class="bowling-icon"
  width="160"
  height="140"
  viewBox="0 0 160 140"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  aria-label="Retro bowling scoreboard"
>
  <!-- Scoreboard frame -->
  <rect
    x="10"
    y="10"
    width="140"
    height="120"
    rx="8"
    fill="#2d1f16"
    stroke="#d4a574"
    stroke-width="3"></rect>

  <!-- Inner frame accent -->
  <rect
    x="20"
    y="20"
    width="120"
    height="100"
    rx="4"
    fill="none"
    stroke="#d4a574"
    stroke-width="1"
    opacity="0.5"></rect>

  <!-- Bowling Pins (arranged in triangle) -->
  <g class="pins">
    <!-- Back row (4 pins) -->
    <circle cx="55" cy="50" r="5" fill="#f5f1e8" stroke="#d4a574" stroke-width="1.5"></circle>
    <circle cx="70" cy="50" r="5" fill="#f5f1e8" stroke="#d4a574" stroke-width="1.5"></circle>
    <circle cx="85" cy="50" r="5" fill="#f5f1e8" stroke="#d4a574" stroke-width="1.5"></circle>
    <circle cx="100" cy="50" r="5" fill="#f5f1e8" stroke="#d4a574" stroke-width="1.5"></circle>

    <!-- Third row (3 pins) -->
    <circle cx="62" cy="62" r="5" fill="#f5f1e8" stroke="#d4a574" stroke-width="1.5"></circle>
    <circle cx="78" cy="62" r="5" fill="#f5f1e8" stroke="#d4a574" stroke-width="1.5"></circle>
    <circle cx="93" cy="62" r="5" fill="#f5f1e8" stroke="#d4a574" stroke-width="1.5"></circle>

    <!-- Second row (2 pins) -->
    <circle cx="70" cy="74" r="5" fill="#f5f1e8" stroke="#d4a574" stroke-width="1.5"></circle>
    <circle cx="85" cy="74" r="5" fill="#f5f1e8" stroke="#d4a574" stroke-width="1.5"></circle>

    <!-- Front pin -->
    <circle cx="77.5" cy="86" r="5.5" fill="#f5f1e8" stroke="#d4a574" stroke-width="2"></circle>
  </g>

  <!-- Retro bowling ball with marbled effect -->
  <g class="ball">
    <circle cx="80" cy="105" r="12" fill="url(#marbleGradient)"></circle>
    <circle cx="76" cy="100" r="2" fill="#1a1410"></circle>
    <circle cx="83" cy="99" r="2" fill="#1a1410"></circle>
    <circle cx="79.5" cy="107" r="2" fill="#1a1410"></circle>
    <!-- Shine effect -->
    <circle cx="75" cy="99" r="3" fill="white" opacity="0.3"></circle>
  </g>

  <!-- Retro strike lights -->
  <g class="lights">
    <circle cx="35" cy="35" r="3" fill="#d97706" opacity="0.8"></circle>
    <circle cx="125" cy="35" r="3" fill="#d97706" opacity="0.8"></circle>
  </g>

  <!-- Gradients -->
  <defs>
    <radialGradient id="marbleGradient">
      <stop offset="0%" style="stop-color:#ea580c;stop-opacity:1"></stop>
      <stop offset="50%" style="stop-color:#c2410c;stop-opacity:1"></stop>
      <stop offset="100%" style="stop-color:#7c2d12;stop-opacity:1"></stop>
    </radialGradient>
  </defs>
</svg>

<style>
  .bowling-icon {
    filter: drop-shadow(0 8px 16px rgba(212, 165, 116, 0.2));
    animation: float 3s ease-in-out infinite;
  }

  .pins {
    animation: pinShake 3s ease-in-out infinite;
    transform-origin: 77.5px 68px;
  }

  .ball {
    animation: ballRoll 4s ease-in-out infinite;
    transform-origin: 80px 105px;
  }

  .lights {
    animation: blink 1.5s ease-in-out infinite;
  }

  @keyframes float {
    0%,
    100% {
      transform: translateY(0px);
    }
    50% {
      transform: translateY(-6px);
    }
  }

  @keyframes pinShake {
    0%,
    100% {
      transform: rotate(0deg);
    }
    25% {
      transform: rotate(-1deg);
    }
    75% {
      transform: rotate(1deg);
    }
  }

  @keyframes ballRoll {
    0%,
    100% {
      transform: rotate(0deg);
    }
    50% {
      transform: rotate(180deg);
    }
  }

  @keyframes blink {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0.3;
    }
  }
</style>
