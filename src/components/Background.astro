---
// Retro bowling alley background with wood paneling and lanes
---

<!-- Retro wood paneling background -->
<div class="wood-paneling"></div>

<!-- Vintage dots pattern -->
<div class="dots-pattern"></div>

<!-- Retro lanes with maple wood texture -->
<div class="bowling-lanes">
	<div class="lane"></div>
	<div class="lane"></div>
	<div class="lane"></div>
</div>

<style>
	/* Retro wood paneling texture */
	.wood-paneling {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		background: repeating-linear-gradient(
			90deg,
			rgba(101, 67, 33, 0.03) 0px,
			rgba(101, 67, 33, 0.03) 2px,
			transparent 2px,
			transparent 50px
		);
		opacity: 0.4;
	}

	/* Vintage dots pattern */
	.dots-pattern {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		background-image: radial-gradient(
			circle,
			rgba(212, 165, 116, 0.05) 1px,
			transparent 1px
		);
		background-size: 30px 30px;
	}

	/* Bowling lanes with maple wood look */
	.bowling-lanes {
		position: absolute;
		bottom: 0;
		left: 0;
		width: 100%;
		height: 100vh;
		display: flex;
		gap: 20px;
		padding: 0 5%;
		opacity: 0.3;
		z-index: 1;
	}

	.lane {
		flex: 1;
		background: linear-gradient(
			180deg,
			rgba(212, 165, 116, 0.2) 0%,
			rgba(212, 165, 116, 0.1) 50%,
			rgba(212, 165, 116, 0.2) 100%
		);
		border-left: 1px solid rgba(212, 165, 116, 0.3);
		border-right: 1px solid rgba(212, 165, 116, 0.3);
	}

	/* Responsive Design */
	@media (max-width: 768px) {
		.bowling-lanes {
			gap: 10px;
			height: 40px;
		}
	}
</style>
